{
  "name": "@hyprpay/alchemy",
  "version": "0.0.0",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./gateways": {
      "types": "./dist/gateways.d.ts",
      "import": "./dist/gateways.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "bun ../../tooling/bunup/index.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests",
    "publint": "bunx publint --strict"
  },
  "dependencies": {
    "@effect/platform-bun": "4.0.0-beta.85",
    "@effect/platform-node": "4.0.0-beta.85",
    "@hyprpay/core": "workspace:*",
    "@hyprpay/gateway-abacate-pay": "workspace:*",
    "@hyprpay/gateway-asaas": "workspace:*",
    "alchemy": "^2.0.0-beta.57",
    "effect": "4.0.0-beta.85"
  }
}
