{
  "name": "@hyprpay/better-auth",
  "version": "0.0.0",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/server.js",
  "types": "./dist/server.d.ts",
  "exports": {
    ".": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "bun ../../tooling/bunup/index.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "publint": "bunx publint --strict"
  },
  "dependencies": {
    "@better-fetch/fetch": "1.3.1",
    "@hyprpay/core": "workspace:*",
    "better-auth": "1.6.20",
    "effect": "4.0.0-beta.85"
  }
}
