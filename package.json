{
  "name": "hyprpay",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.14",
  "workspaces": ["core", "core/cli", "apps/*", "gateways/*", "stores/*", "integrations/*", "tooling/*"],
  "scripts": {
    "build": "nx run-many -t build",
    "typecheck": "nx run-many -t typecheck",
    "test": "nx run-many -t test",
    "publint": "nx run-many -t publint",
    "check:static": "bun tooling/static-checks/check-clean-code.ts",
    "check": "bun run check:static && bun run typecheck && bun run test && bun run build"
  },
  "devDependencies": {
    "@effect/vitest": "4.0.0-beta.85",
    "@types/bun": "latest",
    "nx": "latest",
    "vitest": "4.1.9",
    "typescript": "latest"
  }
}
