---
import "../styles/global.css";

interface Props {
  title: string;
  description: string;
  active: string;
  eyebrow?: string;
}

const { title, description, active, eyebrow = "Gateway-agnostic billing" } = Astro.props;
const nav = [
  { href: "/", label: "Introduction", key: "intro" },
  { href: "/quickstart", label: "Quickstart", key: "quickstart" },
  { href: "/architecture", label: "Architecture", key: "architecture" },
  { href: "/cli", label: "CLI", key: "cli" },
  { href: "/better-auth", label: "Better Auth", key: "better-auth" },
  { href: "/entitlements", label: "Entitlements", key: "entitlements" },
  { href: "/gateways", label: "Gateways", key: "gateways" },
];
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title} | HyprPay</title>
  </head>
  <body>
    <div class="site-shell">
      <aside class="sidebar">
        <a class="brand" href="/" aria-label="HyprPay home">
          <span class="brand-mark">H</span>
          <span>HyprPay</span>
        </a>
        <nav aria-label="Docs navigation">
          {nav.map(item => (
            <a class:list={["nav-link", { active: item.key === active }]} href={item.href}>{item.label}</a>
          ))}
        </nav>
      </aside>
      <main class="content">
        <header class="page-hero">
          <p class="eyebrow">{eyebrow}</p>
          <h1>{title}</h1>
          <p class="lead">{description}</p>
        </header>
        <slot />
      </main>
    </div>
  </body>
</html>
