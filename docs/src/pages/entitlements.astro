---
import Hero from "../components/hero.astro";
import Section from "../components/section.astro";
import BaseLayout from "../layouts/base-layout.astro";

const checkCode = `const access = await Effect.runPromise(
  hyprpay.entitlements.check({
    customerId: customer.id,
    featureId: "messages",
    amount: 1,
  }),
);

if (!access.allowed) {
  return Response.json({ error: "Limite de uso atingido." }, { status: 403 });
}`;
const reportCode = `const response = await generateMessage(input);

await Effect.runPromise(
  hyprpay.entitlements.report({
    customerId: customer.id,
    featureId: "messages",
    amount: 1,
    idempotencyKey: requestId,
  }),
);

return Response.json(response);`;
---
<BaseLayout title="Entitlements" description="Gate product behavior through local feature grants and metered balances." active="/entitlements">
  <Hero
    eyebrow="Entitlements"
    title="Check first. Report only after success."
    description="HyprPay resolves feature access from active paid plans first, then falls back to default catalog grants."
  />

  <Section>
    <div class="grid gap-5 md:grid-cols-3">
      <article class="rounded-3xl border border-white/10 bg-white/5 p-6"><h3 class="text-xl font-bold text-white">Boolean</h3><p class="mt-3 leading-7 text-slate-300">Use for premium access, priority support, or feature gates.</p></article>
      <article class="rounded-3xl border border-white/10 bg-white/5 p-6"><h3 class="text-xl font-bold text-white">Metered</h3><p class="mt-3 leading-7 text-slate-300">Use for messages, exports, credits, API calls, or AI generations.</p></article>
      <article class="rounded-3xl border border-white/10 bg-white/5 p-6"><h3 class="text-xl font-bold text-white">Idempotent</h3><p class="mt-3 leading-7 text-slate-300">Report usage with idempotency keys so retries do not double charge balances.</p></article>
    </div>
  </Section>

  <Section eyebrow="Before work" title="Check access before consuming resources.">
    <pre><code>{checkCode}</code></pre>
  </Section>

  <Section eyebrow="After success" title="Report usage only when the action succeeds.">
    <pre><code>{reportCode}</code></pre>
  </Section>
</BaseLayout>
