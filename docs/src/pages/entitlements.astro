---
import Features from "../components/features.astro";
import Hero from "../components/hero.astro";
import Section from "../components/section.astro";
import BaseLayout from "../layouts/base-layout.astro";

const checkCode = `const access = await Effect.runPromise(
  hyprpay.entitlements.check({
    customerId: customer.id,
    featureId: "messages",
    amount: 1,
  }),
);

if (!access.allowed) {
  return Response.json({ error: "Limite de uso atingido." }, { status: 403 });
}`;
const reportCode = `const response = await renderExport(input);

await Effect.runPromise(
  hyprpay.entitlements.report({
    customerId: customer.id,
    featureId: "messages",
    amount: 1,
    idempotencyKey: requestId,
  }),
);

return Response.json(response);`;
---
<BaseLayout title="Entitlements" description="Controle acesso do produto com grants locais e saldos medidos." active="/entitlements">
  <Hero
    eyebrow="Entitlements"
    title="Cheque antes. Registre depois."
    description="HyprPay resolve acesso com subscriptions ativas e grants do catálogo. Uso só é consumido quando a ação termina com sucesso."
  />

  <Section>
    <Features
      items={[
        {
          icon: "toggle-right",
          title: "Boolean",
          description: "Use para acesso premium, suporte prioritário ou feature gates.",
        },
        {
          icon: "gauge",
          title: "Metered",
          description: "Use para mensagens, exports, créditos ou chamadas de API.",
        },
        {
          icon: "fingerprint",
          title: "Idempotência",
          description: "Reporte uso com idempotency key para retries não consumirem saldo duas vezes.",
        },
      ]}
    />
  </Section>

  <Section eyebrow="Antes" title="Cheque acesso antes de consumir recurso.">
    <pre><code>{checkCode}</code></pre>
  </Section>

  <Section eyebrow="Depois" title="Reporte uso só depois do sucesso.">
    <pre><code>{reportCode}</code></pre>
  </Section>
</BaseLayout>
