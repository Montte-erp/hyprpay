---
import Features from "../components/features.astro";
import Hero from "../components/hero.astro";
import Section from "../components/section.astro";
import BaseLayout from "../layouts/base-layout.astro";

const checkCode = `const access = await Effect.runPromise(
  hyprpay.entitlements.check({
    customerId: customer.id,
    featureId: "messages",
    amount: 1,
  }),
);

if (!access.allowed) {
  return Response.json({ error: "Limite de uso atingido." }, { status: 403 });
}`;
const reportCode = `const response = await generateMessage(input);

await Effect.runPromise(
  hyprpay.entitlements.report({
    customerId: customer.id,
    featureId: "messages",
    amount: 1,
    idempotencyKey: requestId,
  }),
);

return Response.json(response);`;
---
<BaseLayout title="Entitlements" description="Controle comportamento do produto com feature grants locais e saldos metered." active="/entitlements">
  <Hero
    eyebrow="Entitlements"
    title="Cheque antes. Reporte só depois do sucesso."
    description="HyprPay resolve acesso por planos pagos ativos primeiro e cai para grants default do catálogo quando não há assinatura ativa."
  />

  <Section>
    <Features
      items={[
        {
          icon: "toggle-right",
          title: "Boolean",
          description: "Use para premium access, suporte prioritário ou feature gates.",
        },
        {
          icon: "gauge",
          title: "Metered",
          description: "Use para mensagens, exports, créditos, chamadas de API ou gerações de IA.",
        },
        {
          icon: "fingerprint",
          title: "Idempotente",
          description: "Reporte uso com idempotency key para retries não consumirem saldo duas vezes.",
        },
      ]}
    />
  </Section>

  <Section eyebrow="Antes do trabalho" title="Cheque acesso antes de consumir recurso.">
    <pre><code>{checkCode}</code></pre>
  </Section>

  <Section eyebrow="Depois do sucesso" title="Reporte uso somente quando a ação der certo.">
    <pre><code>{reportCode}</code></pre>
  </Section>
</BaseLayout>
