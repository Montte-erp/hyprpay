---
import Features from "../components/features.astro";
import Hero from "../components/hero.astro";
import Section from "../components/section.astro";
import BaseLayout from "../layouts/base-layout.astro";

const catalogCode = `import { benefit, createHyprPay, feature, plan, product } from "@hyprpay/core";
import { createAsaasProvider } from "@hyprpay/gateway-asaas";
import { postgresStore } from "@hyprpay/store-postgres";

const messages = feature.metered({ id: "messages", reset: "month" });
const seats = benefit.seats({ id: "team-seats", quantity: 5 });

const pro = plan({
  id: "pro",
  group: "base",
  price: { amountMinor: 1990, currency: "BRL", interval: "month" },
  includes: [messages({ limit: 2_000 }), seats],
});

export const hyprpay = createHyprPay({
  catalog: [product({ id: "app", name: "App", plans: [pro] })],
  store: postgresStore({ db }),
  provider: createAsaasProvider({ apiKey: env.ASAAS_API_KEY, server: "sandbox" }),
});`;
---
<BaseLayout
  title="HyprPay"
  description="Billing em TypeScript para apps brasileiros com catálogo em código, entitlements locais e Postgres como fonte da verdade."
  active="/"
>
  <Hero
    eyebrow="Billing em TypeScript"
    title="Billing sem prender seu app ao gateway."
    description="Defina produtos, planos e limites uma vez. Use Asaas ou Abacate Pay atrás do mesmo runtime."
    actions={[
      { href: "/quickstart", label: "Integrar agora" },
      { href: "/architecture", label: "Ver arquitetura", variant: "secondary" },
    ]}
  />

  <Section eyebrow="O que é" title="Um framework de billing embutido no seu app." description="HyprPay guarda o estado no seu Postgres, chama gateways só nas bordas e expõe APIs pequenas para checkout, assinaturas e entitlements.">
    <Features
      items={[
        {
          icon: "book-open-check",
          title: "Catálogo em código",
          description: "Produtos, planos, preços e limites ficam versionados junto da aplicação.",
        },
        {
          icon: "gauge",
          title: "Entitlements locais",
          description: "Cheque acesso, registre uso e aplique benefícios sem consultar o gateway.",
        },
        {
          icon: "plug-zap",
          title: "Gateways na borda",
          description: "Asaas e Abacate Pay implementam o mesmo contrato normalizado do core.",
        },
      ]}
    />
  </Section>

  <Section eyebrow="Exemplo" title="Crie a instância server-side.">
    <pre><code>{catalogCode}</code></pre>
  </Section>
</BaseLayout>
