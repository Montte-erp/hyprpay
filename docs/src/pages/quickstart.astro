---
import { DatabaseZap, PackagePlus } from "@lucide/astro";
import Hero from "../components/hero.astro";
import Section from "../components/section.astro";
import BaseLayout from "../layouts/base-layout.astro";

const configCode = `import { createHyprPay, feature, plan, product } from "@hyprpay/core";
import { createAsaasProvider } from "@hyprpay/gateway-asaas";
import { postgresStore } from "@hyprpay/store-postgres";

const messages = feature.metered({ id: "messages", reset: "month" });
const free = plan({ id: "free", group: "base", default: true, includes: [messages({ limit: 100 })] });
const pro = plan({
  id: "pro",
  group: "base",
  price: { amountMinor: 1990, currency: "BRL", interval: "month" },
  includes: [messages({ limit: 2_000 })],
});

export const hyprpay = createHyprPay({
  catalog: [product({ id: "app", name: "App", plans: [free, pro] })],
  store: postgresStore({ db }),
  provider: createAsaasProvider({ apiKey: env.ASAAS_API_KEY, server: "sandbox" }),
});`;

const checkoutCode = `const customer = await Effect.runPromise(
  hyprpay.customers.create({ externalId: "user_123", name: "Empresa XPTO" }),
);

const checkout = await Effect.runPromise(
  hyprpay.checkouts.create({
    customerId: customer.id,
    planId: "pro",
    amount: 1990,
    methods: ["pix"],
    successUrl: "https://app.example.com/billing/success",
    cancelUrl: "https://app.example.com/billing",
  }),
);`;
---
<BaseLayout title="Quickstart" description="Instale HyprPay, configure Postgres, defina o catálogo e crie seu primeiro checkout." active="/quickstart">
  <Hero
    eyebrow="Quickstart"
    title="Do app vazio ao checkout em quatro passos."
    description="Mantenha configuração de gateway na borda e deixe HyprPay controlar registros, versões de catálogo e entitlements."
  />

  <Section>
    <div class="grid gap-5 lg:grid-cols-2">
      <article class="rounded-3xl border border-white/10 bg-white/5 p-6">
        <PackagePlus class="mb-5 h-8 w-8 text-cyan-300" aria-hidden="true" />
        <span class="text-sm font-bold uppercase tracking-[0.18em] text-cyan-300">Passo 1</span>
        <h2 class="mt-3 text-2xl font-bold text-white">Instale os packages</h2>
        <pre><code>bun add @hyprpay/core @hyprpay/store-postgres @hyprpay/gateway-asaas effect drizzle-orm</code></pre>
      </article>
      <article class="rounded-3xl border border-white/10 bg-white/5 p-6">
        <DatabaseZap class="mb-5 h-8 w-8 text-cyan-300" aria-hidden="true" />
        <span class="text-sm font-bold uppercase tracking-[0.18em] text-cyan-300">Passo 2</span>
        <h2 class="mt-3 text-2xl font-bold text-white">Sincronize antes do deploy</h2>
        <pre><code>bunx hyprpay push -y</code></pre>
      </article>
    </div>
  </Section>

  <Section eyebrow="Config" title="Crie um módulo server-only do HyprPay.">
    <pre><code>{configCode}</code></pre>
  </Section>

  <Section eyebrow="Checkout" title="Crie customer e redirecione para pagamento.">
    <pre><code>{checkoutCode}</code></pre>
  </Section>
</BaseLayout>
