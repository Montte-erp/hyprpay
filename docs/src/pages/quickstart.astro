---
import Hero from "../components/hero.astro";
import Section from "../components/section.astro";
import Steps from "../components/steps.astro";
import BaseLayout from "../layouts/base-layout.astro";

const configCode = `import { createHyprPay, feature, plan, product } from "@hyprpay/core";
import { createAsaasProvider } from "@hyprpay/gateway-asaas";
import { postgresStore } from "@hyprpay/store-postgres";

const messages = feature.metered({ id: "messages", reset: "month" });
const free = plan({ id: "free", group: "base", default: true, includes: [messages({ limit: 100 })] });
const pro = plan({
  id: "pro",
  group: "base",
  price: { amountMinor: 1990, currency: "BRL", interval: "month" },
  includes: [messages({ limit: 2_000 })],
});

export const hyprpay = createHyprPay({
  catalog: [product({ id: "app", name: "App", plans: [free, pro] })],
  store: postgresStore({ db }),
  provider: createAsaasProvider({ apiKey: env.ASAAS_API_KEY, server: "sandbox" }),
});`;

const steps = [
  {
    title: "Instale os pacotes",
    description: "Use core, store Postgres, gateway e Effect no lado server do app.",
    code: "bun add @hyprpay/core @hyprpay/store-postgres @hyprpay/gateway-asaas effect drizzle-orm",
  },
  {
    title: "Crie a instância",
    description: "Exporte um único módulo server-only com catálogo, store e provider.",
  },
  {
    title: "Sincronize no deploy",
    description: "A CLI aplica o setup do banco e grava versões imutáveis do catálogo.",
    code: "bunx hyprpay push -y",
  },
  {
    title: "Crie checkouts",
    description: "A API recebe IDs locais; o gateway só retorna a URL de pagamento normalizada.",
  },
];

const checkoutCode = `const customer = await Effect.runPromise(
  hyprpay.customers.create({ externalId: "user_123", name: "Empresa XPTO" }),
);

const checkout = await Effect.runPromise(
  hyprpay.checkouts.create({
    customerId: customer.id,
    planId: "pro",
    amount: 1990,
    methods: ["pix"],
    successUrl: "https://app.example.com/billing/success",
    cancelUrl: "https://app.example.com/billing",
  }),
);`;
---
<BaseLayout title="Quickstart" description="Instale HyprPay, configure Postgres, defina o catálogo e crie seu primeiro checkout." active="/quickstart">
  <Hero
    eyebrow="Quickstart"
    title="Instale, configure, sincronize."
    description="O fluxo é o mesmo de migrations: defina billing em código, rode push antes do deploy e use a API server-side."
  />

  <Section eyebrow="Passos" title="Setup mínimo.">
    <Steps items={steps} />
  </Section>

  <Section eyebrow="Config" title="Arquivo server-only.">
    <pre><code>{configCode}</code></pre>
  </Section>

  <Section eyebrow="Checkout" title="Crie o customer e redirecione.">
    <pre><code>{checkoutCode}</code></pre>
  </Section>
</BaseLayout>
