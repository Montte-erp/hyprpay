---
import Features from "../components/features.astro";
import Hero from "../components/hero.astro";
import Section from "../components/section.astro";
import BaseLayout from "../layouts/base-layout.astro";

const asaasCode = `import { createAsaasProvider } from "@hyprpay/gateway-asaas";

const provider = createAsaasProvider({
  apiKey: process.env.ASAAS_API_KEY ?? "",
  server: "sandbox",
  webhookToken: process.env.ASAAS_WEBHOOK_TOKEN,
});`;
const abacateCode = `import { createAbacatePayProvider } from "@hyprpay/gateway-abacate-pay";

const provider = createAbacatePayProvider({
  apiKey: process.env.ABACATE_PAY_API_KEY ?? "",
  webhookSecret: process.env.ABACATE_PAY_WEBHOOK_SECRET,
});`;
---
<BaseLayout title="Gateways" description="Use Asaas ou Abacate Pay atrás do mesmo contrato HyprPay." active="/gateways">
  <Hero
    eyebrow="Gateways"
    title="Troque gateway sem trocar billing."
    description="Adapters traduzem requests, responses e webhooks. Catálogo, entitlements e estado ficam no HyprPay."
  />

  <Section>
    <Features
      columns={2}
      items={[
        {
          icon: "credit-card",
          title: "Asaas",
          description: "PIX, boleto, cartão, checkout hospedado e webhooks normalizados.",
          code: asaasCode,
        },
        {
          icon: "plug-zap",
          title: "Abacate Pay",
          description: "Segundo gateway usando o mesmo contrato de checkout e webhook.",
          code: abacateCode,
        },
      ]}
    />
  </Section>

  <Section eyebrow="Boundary" title="O que não passa do adapter.">
    <Features
      columns={2}
      items={[
        {
          icon: "shield-check",
          title: "Response normalizada",
          description: "API pública retorna schemas do HyprPay, não payload do provider.",
        },
        {
          icon: "file-check",
          title: "Erro tipado",
          description: "Capability ausente falha no error channel do Effect.",
        },
        {
          icon: "webhook",
          title: "Webhook bruto isolado",
          description: "Payload bruto de webhook só vive em BillingEvent.payload.",
        },
        {
          icon: "layers",
          title: "Core sem SDK externo",
          description: "Core não importa SDK de gateway nem detalhes provider-specific.",
        },
      ]}
    />
  </Section>
</BaseLayout>
