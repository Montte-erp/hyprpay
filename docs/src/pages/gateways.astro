---
import Features from "../components/features.astro";
import Hero from "../components/hero.astro";
import Section from "../components/section.astro";
import BaseLayout from "../layouts/base-layout.astro";

const asaasCode = `import { createAsaasProvider } from "@hyprpay/gateway-asaas";

const provider = createAsaasProvider({
  apiKey: process.env.ASAAS_API_KEY ?? "",
  server: "sandbox",
  webhookToken: process.env.ASAAS_WEBHOOK_TOKEN,
});`;
const abacateCode = `import { createAbacatePayProvider } from "@hyprpay/gateway-abacate-pay";

const provider = createAbacatePayProvider({
  apiKey: process.env.ABACATE_PAY_API_KEY ?? "",
  webhookSecret: process.env.ABACATE_PAY_WEBHOOK_SECRET,
});`;
---
<BaseLayout title="Gateways" description="Use Asaas ou Abacate Pay atrás do mesmo contrato de provider HyprPay." active="/gateways">
  <Hero
    eyebrow="Gateways"
    title="Adapters de provider ficam chatos."
    description="Gateways traduzem requests e normalizam webhooks. Benefits, entitlements e catálogo continuam capabilities locais do HyprPay."
  />

  <Section>
    <Features
      columns={2}
      items={[
        {
          icon: "credit-card",
          title: "Asaas",
          description: "PIX, boleto, cartão, hosted checkout e normalização de webhook para billing brasileiro.",
          code: asaasCode,
        },
        {
          icon: "plug-zap",
          title: "Abacate Pay",
          description: "Segundo gateway para provar que o contrato do core é provider-agnostic.",
          code: abacateCode,
        },
      ]}
    />
  </Section>

  <Section eyebrow="Adapter boundary" title="O que gateway nunca deve vazar.">
    <Features
      columns={2}
      items={[
        {
          icon: "shield-check",
          title: "Resposta pública normalizada",
          description: "Response bruto de provider não cruza sucesso da API pública.",
        },
        {
          icon: "file-check",
          title: "Falha tipada",
          description: "Capability ausente falha com erro Effect tipado.",
        },
        {
          icon: "webhook",
          title: "Webhook bruto isolado",
          description: "Payload bruto de webhook só vive em BillingEvent.payload.",
        },
        {
          icon: "layers",
          title: "Core sem SDK externo",
          description: "Core não importa SDK de gateway nem detalhes provider-specific.",
        },
      ]}
    />
  </Section>
</BaseLayout>
