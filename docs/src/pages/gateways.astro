---
import Hero from "../components/hero.astro";
import Section from "../components/section.astro";
import BaseLayout from "../layouts/base-layout.astro";

const asaasCode = `import { createAsaasProvider } from "@hyprpay/gateway-asaas";

const provider = createAsaasProvider({
  apiKey: process.env.ASAAS_API_KEY ?? "",
  server: "sandbox",
  webhookToken: process.env.ASAAS_WEBHOOK_TOKEN,
});`;
const abacateCode = `import { createAbacatePayProvider } from "@hyprpay/gateway-abacate-pay";

const provider = createAbacatePayProvider({
  apiKey: process.env.ABACATE_PAY_API_KEY ?? "",
  webhookSecret: process.env.ABACATE_PAY_WEBHOOK_SECRET,
});`;
---
<BaseLayout title="Gateways" description="Use Asaas or Abacate Pay behind the same HyprPay provider contract." active="/gateways">
  <Hero
    eyebrow="Gateways"
    title="Provider adapters stay boring."
    description="Gateways translate requests and normalize webhooks. Benefits, entitlements, and catalog state remain local HyprPay capabilities."
  />

  <Section>
    <div class="grid gap-5 lg:grid-cols-2">
      <article class="rounded-3xl border border-white/10 bg-white/5 p-6">
        <h2 class="text-2xl font-bold text-white">Asaas</h2>
        <p class="mt-3 leading-7 text-slate-300">PIX, boleto, card, hosted checkout, and webhook normalization for Brazilian billing.</p>
        <pre><code>{asaasCode}</code></pre>
      </article>
      <article class="rounded-3xl border border-white/10 bg-white/5 p-6">
        <h2 class="text-2xl font-bold text-white">Abacate Pay</h2>
        <p class="mt-3 leading-7 text-slate-300">A second gateway proving the core contract is provider agnostic.</p>
        <pre><code>{abacateCode}</code></pre>
      </article>
    </div>
  </Section>

  <Section eyebrow="Adapter boundary" title="What gateways must never leak.">
    <ul class="grid gap-3 text-slate-300 md:grid-cols-2">
      <li class="rounded-2xl border border-white/10 bg-white/5 p-4">Raw provider success responses do not cross the public API.</li>
      <li class="rounded-2xl border border-white/10 bg-white/5 p-4">Unsupported capabilities fail with typed Effect errors.</li>
      <li class="rounded-2xl border border-white/10 bg-white/5 p-4">Raw webhook payloads only live on <code>BillingEvent.payload</code>.</li>
      <li class="rounded-2xl border border-white/10 bg-white/5 p-4">Core stays free of gateway SDKs and provider-specific checkout details.</li>
    </ul>
  </Section>
</BaseLayout>
