---
import Hero from "../components/hero.astro";
import Section from "../components/section.astro";
import BaseLayout from "../layouts/base-layout.astro";

const serverCode = `import { betterAuth } from "better-auth";
import { betterAuthHyprPay } from "@hyprpay/better-auth";
import { hyprpay } from "./hyprpay";

export const auth = betterAuth({
  plugins: [betterAuthHyprPay({ hyprpay })],
});`;
const clientCode = `import { createAuthClient } from "better-auth/client";
import { betterAuthHyprPayClient } from "@hyprpay/better-auth/client";

export const authClient = createAuthClient({
  plugins: [betterAuthHyprPayClient()],
});`;
const upgradeCode = `const result = await authClient.hyprpay.subscription.upgrade({
  planId: "pro",
  successUrl: "/billing/success",
  cancelUrl: "/billing",
});

if (result.data?.checkout.checkoutUrl) {
  window.location.href = result.data.checkout.checkoutUrl;
}`;
---
<BaseLayout title="Better Auth" description="Attach HyprPay to Better Auth with server and client plugins." active="/better-auth">
  <Hero
    eyebrow="Integration"
    title="Better Auth users, HyprPay billing state."
    description="Keep authentication and billing connected without making Better Auth own your billing model or gateway choices."
  />

  <Section eyebrow="Server" title="Register the server plugin.">
    <pre><code>{serverCode}</code></pre>
  </Section>

  <Section eyebrow="Client" title="Expose typed billing actions to UI code.">
    <pre><code>{clientCode}</code></pre>
  </Section>

  <Section eyebrow="Upgrade" title="Start checkout from the authenticated client.">
    <pre><code>{upgradeCode}</code></pre>
  </Section>

  <Section>
    <div class="grid gap-5 md:grid-cols-3">
      <article class="rounded-3xl border border-white/10 bg-white/5 p-6"><h3 class="text-xl font-bold text-white">Customer sync</h3><p class="mt-3 leading-7 text-slate-300">Better Auth user ID maps to <code>Customer.externalId</code>.</p></article>
      <article class="rounded-3xl border border-white/10 bg-white/5 p-6"><h3 class="text-xl font-bold text-white">Local list</h3><p class="mt-3 leading-7 text-slate-300">Subscriptions are read from HyprPay Postgres records.</p></article>
      <article class="rounded-3xl border border-white/10 bg-white/5 p-6"><h3 class="text-xl font-bold text-white">Portal session</h3><p class="mt-3 leading-7 text-slate-300">The client requests a billing portal without gateway details.</p></article>
    </div>
  </Section>
</BaseLayout>
