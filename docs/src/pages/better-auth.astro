---
import Features from "../components/features.astro";
import Hero from "../components/hero.astro";
import Section from "../components/section.astro";
import BaseLayout from "../layouts/base-layout.astro";

const serverCode = `import { betterAuth } from "better-auth";
import { betterAuthHyprPay } from "@hyprpay/better-auth";
import { hyprpay } from "./hyprpay";

export const auth = betterAuth({
  plugins: [betterAuthHyprPay({ hyprpay })],
});`;
const clientCode = `import { createAuthClient } from "better-auth/client";
import { betterAuthHyprPayClient } from "@hyprpay/better-auth/client";

export const authClient = createAuthClient({
  plugins: [betterAuthHyprPayClient()],
});`;
const upgradeCode = `const result = await authClient.hyprpay.subscription.upgrade({
  planId: "pro",
  successUrl: "/billing/success",
  cancelUrl: "/billing",
});

if (result.data?.checkout.checkoutUrl) {
  window.location.href = result.data.checkout.checkoutUrl;
}`;
---
<BaseLayout title="Better Auth" description="Conecte HyprPay ao Better Auth com plugin server e client." active="/better-auth">
  <Hero
    eyebrow="Integration"
    title="Usuários Better Auth, billing state HyprPay."
    description="O plugin sincroniza o usuário autenticado como customer, cria checkout de upgrade, lista subscriptions locais e cria portal sessions."
  />

  <Section eyebrow="Server" title="Adicione o plugin no auth server.">
    <pre><code>{serverCode}</code></pre>
  </Section>

  <Section eyebrow="Client" title="Expose ações de billing no auth client.">
    <pre><code>{clientCode}</code></pre>
  </Section>

  <Section eyebrow="Upgrade" title="Chame checkout sem saber qual gateway está ligado.">
    <pre><code>{upgradeCode}</code></pre>
    <div class="mt-8">
      <Features
        items={[
          {
            icon: "user-check",
            title: "Customer sync",
            description: "O ID do usuário Better Auth vira Customer.externalId.",
          },
          {
            icon: "repeat",
            title: "Subscriptions locais",
            description: "A listagem lê o banco HyprPay, não o gateway.",
          },
          {
            icon: "door-open",
            title: "Portal",
            description: "A sessão do portal mantém a app desacoplada de provider.",
          },
        ]}
      />
    </div>
  </Section>
</BaseLayout>
