---
import Features from "../components/features.astro";
import { Card, CardContent } from "../components/starwind/card";
import Hero from "../components/hero.astro";
import Section from "../components/section.astro";
import BaseLayout from "../layouts/base-layout.astro";

const layers = [
  ["core/*", "APIs de domínio: customers, checkouts, subscriptions, webhooks, benefits, entitlements, meters, seats, portal sessions e license keys."],
  ["stores/postgres", "Fonte durável da verdade com Drizzle Postgres e versões imutáveis de catálogo."],
  ["gateways/*", "Adapters substituíveis para Asaas e Abacate Pay. Eles traduzem provider bruto para contratos do core."],
  ["integrations/*", "Glue opcional para Better Auth e Alchemy v2 sem contaminar o runtime principal."],
  ["docs/", "Astro docs com componentes Starwind, Tailwind v4, Sora e conteúdo original de integração."],
];
---
<BaseLayout title="Arquitetura" description="Comparação da arquitetura HyprPay com Better Auth, PayKit e Starwind." active="/architecture">
  <Hero
    eyebrow="Architecture"
    title="Core pequeno, módulos fundos, zero lock-in."
    description="HyprPay mantém o catálogo estilo PayKit e o shape de plugin do Better Auth, mas empurra todo trabalho provider-specific para adapters finos."
  />

  <Section eyebrow="Comparação" title="O que fica de cada referência.">
    <Features
      items={[
        {
          icon: "blocks",
          title: "Better Auth",
          description: "Factory-first, plugins server/client separados, mesmo id nos dois lados e endpoints namespaced.",
        },
        {
          icon: "book-open-check",
          title: "PayKit",
          description: "Catálogo em código, sync no deploy, status check em CI e entitlement como primitiva de produto.",
        },
        {
          icon: "wind",
          title: "Starwind",
          description: "Docs estáticas com componentes de Button/Card, Tailwind v4, tokens CSS e visual SaaS sem JavaScript desnecessário.",
        },
      ]}
    />
  </Section>

  <Section eyebrow="Boundaries" title="A estrutura do repo espelha o runtime.">
    <Card class="overflow-hidden shadow-xl">
      <CardContent class="divide-y divide-border p-0">
        {layers.map(([name, description]) => (
          <div class="grid gap-3 p-5 md:grid-cols-[220px_1fr]">
            <strong class="font-mono text-primary">{name}</strong>
            <p class="m-0 leading-7 text-muted-foreground">{description}</p>
          </div>
        ))}
      </CardContent>
    </Card>
  </Section>

  <Section eyebrow="Invariantes" title="O que não pode quebrar.">
    <Features
      items={[
        {
          icon: "shield-check",
          title: "Sem provider bruto no sucesso",
          description: "Gateways retornam refs normalizadas. Payload original só aparece em BillingEvent.payload.",
        },
        {
          icon: "file-check",
          title: "Capability ausente falha tipada",
          description: "Sem no-op silencioso. Operação não suportada retorna CapabilityUnsupported.",
        },
        {
          icon: "layers",
          title: "Framework fora do core",
          description: "Better Auth e Alchemy são packages opcionais; @hyprpay/core não depende deles.",
        },
      ]}
    />
  </Section>
</BaseLayout>
