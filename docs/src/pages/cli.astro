---
import Features from "../components/features.astro";
import Hero from "../components/hero.astro";
import Section from "../components/section.astro";
import BaseLayout from "../layouts/base-layout.astro";

const configCode = `import { defineHyprPayConfig } from "@hyprpay/cli/config";
import { hyprPayPostgresSchema } from "@hyprpay/store-postgres/schema";
import { drizzle } from "drizzle-orm/bun-sql";
import { catalog } from "./src/billing/catalog";

const db = drizzle({
  connection: { url: process.env.DATABASE_URL ?? "" },
  schema: hyprPayPostgresSchema,
});

export default defineHyprPayConfig({
  db,
  catalog,
});`;
---
<BaseLayout title="CLI" description="Comandos HyprPay para setup, migrations, sync de catálogo e status." active="/cli">
  <Hero
    eyebrow="CLI"
    title="Use a CLI como parte do deploy."
    description="init cria a config. push prepara banco e catálogo. status valida ambiente sem alterar nada."
  />

  <Section>
    <Features
      items={[
        {
          icon: "terminal",
          title: "init",
          description: "Cria a config inicial e mostra o shape esperado de Postgres + catálogo.",
          code: "bunx hyprpay init",
        },
        {
          icon: "upload-cloud",
          title: "push",
          description: "Aplica setup do store e grava versões novas do catálogo.",
          code: "bunx hyprpay push -y",
        },
        {
          icon: "activity",
          title: "status",
          description: "Checa config, conexão com banco, migrations e sync do catálogo.",
          code: "bunx hyprpay status --throw",
        },
      ]}
    />
  </Section>

  <Section eyebrow="Config" title="Aponte para o mesmo banco e catálogo do app.">
    <pre><code>{configCode}</code></pre>
  </Section>

  <Section eyebrow="Produção" title="Rode push antes do build ou start.">
    <pre><code>hyprpay push -y && next build</code></pre>
    <p class="leading-7 text-muted-foreground">É o mesmo lugar onde você rodaria migrations. A versão nova do catálogo fica pronta antes do código novo subir.</p>
  </Section>

  <Section eyebrow="Telemetria" title="PostHog via evlog, opt-in.">
    <pre><code>HYPERPAY_TELEMETRY=1 POSTHOG_API_KEY=phc_... bunx hyprpay status</code></pre>
    <p class="leading-7 text-muted-foreground">Desative com <code>HYPERPAY_TELEMETRY_DISABLED=1</code>, <code>HYPRPAY_TELEMETRY_DISABLED=1</code> ou <code>DO_NOT_TRACK=1</code>.</p>
  </Section>
</BaseLayout>
