---
import Features from "../components/features.astro";
import Hero from "../components/hero.astro";
import Section from "../components/section.astro";
import BaseLayout from "../layouts/base-layout.astro";

const configCode = `import { defineHyprPayConfig } from "@hyprpay/cli/config";
import { hyprPayPostgresSchema } from "@hyprpay/store-postgres/schema";
import { drizzle } from "drizzle-orm/bun-sql";
import { catalog } from "./src/billing/catalog";

const db = drizzle({
  connection: { url: process.env.DATABASE_URL ?? "" },
  schema: hyprPayPostgresSchema,
});

export default defineHyprPayConfig({
  db,
  catalog,
});`;
---
<BaseLayout title="CLI" description="Comandos HyprPay para setup, sync de catálogo, status de deploy e telemetria." active="/cli">
  <Hero
    eyebrow="CLI"
    title="Segurança de deploy para mudanças de billing."
    description="A CLI é pequena de propósito: inicializa config, sincroniza versões de catálogo no Postgres e valida se produção está pronta."
  />

  <Section>
    <Features
      items={[
        {
          icon: "terminal",
          title: "init",
          description: "Cria uma config inicial e mostra o shape esperado de Postgres + catálogo.",
          code: "bunx hyprpay init",
        },
        {
          icon: "upload-cloud",
          title: "push",
          description: "Aplica setup idempotente do store e grava versões imutáveis do catálogo.",
          code: "bunx hyprpay push -y",
        },
        {
          icon: "activity",
          title: "status",
          description: "Falha a CI quando config, banco ou catálogo ainda não estão prontos.",
          code: "bunx hyprpay status --throw",
        },
      ]}
    />
  </Section>

  <Section eyebrow="Config" title="Aponte a CLI para o mesmo banco e catálogo do app.">
    <pre><code>{configCode}</code></pre>
  </Section>

  <Section eyebrow="Telemetry" title="Eventos PostHog via evlog, sempre opt-in.">
    <pre><code>HYPERPAY_TELEMETRY=1 POSTHOG_API_KEY=phc_... bunx hyprpay status</code></pre>
    <p class="leading-7 text-muted-foreground">Opt-out sempre vence com <code>HYPERPAY_TELEMETRY_DISABLED=1</code>, <code>HYPRPAY_TELEMETRY_DISABLED=1</code> ou <code>DO_NOT_TRACK=1</code>.</p>
  </Section>
</BaseLayout>
