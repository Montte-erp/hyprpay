---
import Hero from "../components/hero.astro";
import Section from "../components/section.astro";
import BaseLayout from "../layouts/base-layout.astro";

const configCode = `import { defineHyprPayConfig } from "@hyprpay/cli/config";
import { hyprPayPostgresSchema } from "@hyprpay/store-postgres/schema";
import { drizzle } from "drizzle-orm/bun-sql";
import { catalog } from "./src/billing/catalog";

const db = drizzle({
  connection: { url: process.env.DATABASE_URL ?? "" },
  schema: hyprPayPostgresSchema,
});

export default defineHyprPayConfig({
  db,
  catalog,
});`;
---
<BaseLayout title="CLI" description="HyprPay CLI commands for setup, catalog sync, status checks, and telemetry." active="/cli">
  <Hero
    eyebrow="CLI"
    title="Deploy-time safety for billing changes."
    description="The CLI is intentionally small: initialize config, sync Postgres catalog versions, and check whether production is ready."
  />

  <Section>
    <div class="grid gap-5 lg:grid-cols-3">
      <article class="rounded-3xl border border-white/10 bg-white/5 p-6">
        <h2 class="text-2xl font-bold text-white">init</h2>
        <pre><code>bunx hyprpay init</code></pre>
        <p class="leading-7 text-slate-300">Scaffold starter config and the expected Postgres runtime shape.</p>
      </article>
      <article class="rounded-3xl border border-white/10 bg-white/5 p-6">
        <h2 class="text-2xl font-bold text-white">push</h2>
        <pre><code>bunx hyprpay push -y</code></pre>
        <p class="leading-7 text-slate-300">Apply idempotent store setup and write immutable catalog versions.</p>
      </article>
      <article class="rounded-3xl border border-white/10 bg-white/5 p-6">
        <h2 class="text-2xl font-bold text-white">status</h2>
        <pre><code>bunx hyprpay status --throw</code></pre>
        <p class="leading-7 text-slate-300">Fail CI when billing config, database, or catalog sync is not ready.</p>
      </article>
    </div>
  </Section>

  <Section eyebrow="Config" title="Point the CLI at the same runtime your app uses.">
    <pre><code>{configCode}</code></pre>
  </Section>

  <Section eyebrow="Telemetry" title="Opt-in PostHog events through evlog.">
    <pre><code>HYPERPAY_TELEMETRY=1 POSTHOG_API_KEY=phc_... bunx hyprpay status</code></pre>
    <p class="leading-7 text-slate-300">Opt-out always wins with <code>HYPERPAY_TELEMETRY_DISABLED=1</code>, <code>HYPRPAY_TELEMETRY_DISABLED=1</code>, or <code>DO_NOT_TRACK=1</code>.</p>
  </Section>
</BaseLayout>
