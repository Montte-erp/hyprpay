---

interface StepItem {
  title: string;
  description: string;
  code?: string;
}

interface Props {
  items: readonly StepItem[];
}

const { items } = Astro.props;
---
<ol class="relative ml-4 max-w-3xl border-l border-border">
  {items.map((item, index) => (
    <li class="relative pb-10 pl-8 last:pb-0">
      <span class="absolute -left-[17px] grid h-8 w-8 place-items-center rounded-full border border-border bg-background font-mono text-xs text-foreground">
        {index + 1}
      </span>
      <div class="space-y-3">
        <div>
          <h3 class="font-heading text-xl font-semibold tracking-tight text-foreground">{item.title}</h3>
          <p class="mt-2 text-sm leading-7 text-muted-foreground">{item.description}</p>
        </div>
        {item.code && <pre><code>{item.code}</code></pre>}
      </div>
    </li>
  ))}
</ol>
