---
import { Card, CardContent, CardDescription, CardHeader, CardTitle } from "./starwind/card";

interface StepItem {
  title: string;
  description: string;
  code?: string;
}

interface Props {
  items: readonly StepItem[];
}

const { items } = Astro.props;
---
<ol class="grid gap-4">
  {items.map((item, index) => (
    <li>
      <Card class="overflow-hidden shadow-sm">
        <CardHeader class="grid-cols-[auto_1fr] items-start gap-4">
          <div class="grid h-9 w-9 place-items-center rounded-lg bg-secondary font-mono text-sm font-bold text-secondary-foreground ring-1 ring-border">
            {index + 1}
          </div>
          <div>
            <CardTitle>{item.title}</CardTitle>
            <CardDescription>{item.description}</CardDescription>
          </div>
        </CardHeader>
        {item.code && (
          <CardContent>
            <pre><code>{item.code}</code></pre>
          </CardContent>
        )}
      </Card>
    </li>
  ))}
</ol>
