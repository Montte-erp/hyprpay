---
interface Props {
  eyebrow?: string;
  title?: string;
  description?: string;
  class?: string;
  id?: string;
}

const { eyebrow, title, description, class: className = "", id } = Astro.props;
const sectionId =
  id ??
  (title ?? eyebrow ?? "")
    .toLowerCase()
    .normalize("NFD")
    .replace(/[\\u0300-\\u036f]/g, "")
    .replace(/[^a-z0-9]+/g, "-")
    .replace(/^-|-$/g, "");
---
<section id={sectionId || undefined} class:list={["px-6 py-9 lg:px-10", className]}>
  <div class="max-w-3xl">
    {(eyebrow || title || description) && (
      <div class="mb-6">
        {eyebrow && <p class="text-xs font-semibold uppercase tracking-widest text-muted-foreground">{eyebrow}</p>}
        {title && <h2 class="mt-2 font-heading text-2xl font-semibold tracking-tight text-foreground">{title}</h2>}
        {description && <p class="mt-3 text-base leading-7 text-muted-foreground">{description}</p>}
      </div>
    )}
    <slot />
  </div>
</section>
