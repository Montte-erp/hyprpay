---
interface Props {
  eyebrow?: string;
  title?: string;
  description?: string;
  class?: string;
}

const { eyebrow, title, description, class: className = "" } = Astro.props;
---
<section class:list={["mx-auto max-w-7xl px-4 py-10 sm:px-6 lg:px-8", className]}>
  {(eyebrow || title || description) && (
    <div class="mb-7 max-w-3xl">
      {eyebrow && <p class="text-sm font-semibold uppercase tracking-widest text-primary">{eyebrow}</p>}
      {title && <h2 class="mt-3 font-heading text-3xl font-bold tracking-tight text-foreground sm:text-4xl">{title}</h2>}
      {description && <p class="mt-4 text-base leading-7 text-muted-foreground">{description}</p>}
    </div>
  )}
  <slot />
</section>
