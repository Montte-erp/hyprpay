---
import { ArrowRight } from "@lucide/astro";
import { Button } from "./starwind/button";
interface Action {
  href: string;
  label: string;
  variant?: "primary" | "secondary";
}

interface Props {
  eyebrow: string;
  title: string;
  description: string;
  actions?: readonly Action[];
}

const { eyebrow, title, description, actions = [] } = Astro.props;
---
<section class="border-b border-border px-6 py-10 lg:px-10">
  <div class="flex max-w-3xl flex-col gap-6">
    <div>
      <p class="mb-3 text-xs font-semibold uppercase tracking-widest text-muted-foreground">{eyebrow}</p>
      <h1 class="font-heading text-4xl font-bold tracking-tight text-foreground">{title}</h1>
      <p class="mt-3 text-base leading-7 text-muted-foreground">{description}</p>
    </div>
    {actions.length > 0 && (
      <div class="flex flex-col gap-3 sm:flex-row">
        {actions.map(action => (
          <Button variant={action.variant === "secondary" ? "outline" : "primary"} size="sm" href={action.href}>
            {action.label}
            {action.variant !== "secondary" && <ArrowRight class="ml-2 h-4 w-4" aria-hidden="true" />}
          </Button>
        ))}
      </div>
    )}
  </div>
</section>
