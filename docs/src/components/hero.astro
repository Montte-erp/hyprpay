---
interface Action {
  href: string;
  label: string;
  variant?: "primary" | "secondary";
}

interface Props {
  eyebrow: string;
  title: string;
  description: string;
  actions?: readonly Action[];
}

const { eyebrow, title, description, actions = [] } = Astro.props;
---
<section class="relative overflow-hidden py-16 sm:py-24 lg:py-28">
  <div class="absolute inset-x-0 top-16 -z-10 mx-auto h-64 max-w-4xl rounded-full bg-primary/20 blur-3xl" aria-hidden="true"></div>
  <div class="mx-auto max-w-5xl px-4 text-center sm:px-6 lg:px-8">
    <p class="animate-fade-up text-sm font-bold uppercase tracking-[0.2em] text-cyan-300">{eyebrow}</p>
    <h1 class="animate-fade-up mt-5 font-heading text-5xl font-black leading-[0.92] tracking-[-0.055em] text-white sm:text-7xl lg:text-8xl">{title}</h1>
    <p class="animate-fade-up mx-auto mt-6 max-w-3xl text-lg leading-8 text-slate-300 sm:text-xl">{description}</p>
    {actions.length > 0 && (
      <div class="animate-fade-up mt-9 flex flex-col items-center justify-center gap-3 sm:flex-row">
        {actions.map(action => <a class={action.variant === "secondary" ? "btn-secondary" : "btn-primary"} href={action.href}>{action.label}</a>)}
      </div>
    )}
  </div>
</section>
