---
import { ArrowRight } from "@lucide/astro";
import { Button } from "./starwind/button";
interface Action {
  href: string;
  label: string;
  variant?: "primary" | "secondary";
}

interface Props {
  eyebrow: string;
  title: string;
  description: string;
  actions?: readonly Action[];
}

const { eyebrow, title, description, actions = [] } = Astro.props;
---
<section class="relative py-12 sm:py-16">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="max-w-3xl">
      <p class="inline-flex rounded-full border border-border bg-secondary px-3 py-1 text-xs font-semibold uppercase tracking-widest text-secondary-foreground">
        {eyebrow}
      </p>
      <h1 class="mt-5 font-heading text-4xl font-extrabold leading-tight tracking-tight text-foreground sm:text-5xl">{title}</h1>
      <p class="mt-5 max-w-2xl text-base leading-8 text-muted-foreground sm:text-lg">{description}</p>
      {actions.length > 0 && (
        <div class="mt-8 flex flex-col gap-3 sm:flex-row">
          {actions.map(action => (
            <Button variant={action.variant === "secondary" ? "outline" : "primary"} size="lg" href={action.href}>
              {action.label}
              {action.variant !== "secondary" && <ArrowRight class="ml-2 h-4 w-4" aria-hidden="true" />}
            </Button>
          ))}
        </div>
      )}
    </div>
  </div>
</section>
