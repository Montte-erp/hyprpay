---
import Logo from "./logo.astro";
import { navItems } from "../navigation";
---
<footer class="border-t border-border bg-card/40">
  <div class="mx-auto grid max-w-7xl gap-8 px-4 py-10 sm:px-6 md:grid-cols-[1.4fr_1fr] lg:px-8">
    <div>
      <Logo />
      <p class="mt-4 max-w-xl text-sm leading-7 text-muted-foreground">Core de billing tipado, entitlements locais, Postgres como fonte da verdade e gateways brasileiros substituíveis.</p>
    </div>
    <nav class="grid gap-2 text-sm text-muted-foreground sm:grid-cols-2" aria-label="Navegação do rodapé">
      {navItems.map(item => <a class="hover:text-foreground" href={item.href}>{item.label}</a>)}
    </nav>
  </div>
</footer>
