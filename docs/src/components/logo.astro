---
interface Props {
  class?: string;
}

const { class: className = "" } = Astro.props;
---
<a class:list={["inline-flex items-center gap-2 font-heading text-sm font-bold uppercase tracking-wide text-foreground", className]} href="/" aria-label="HyprPay home">
  <span class="grid h-5 w-5 place-items-center rounded-sm bg-foreground text-[10px] font-black text-background">H</span>
  <span>HyprPay.</span>
</a>
