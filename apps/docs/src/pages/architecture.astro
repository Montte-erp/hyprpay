---
import Features from "../components/features.astro";
import { Card, CardContent } from "../components/starwind/card";
import Hero from "../components/hero.astro";
import Section from "../components/section.astro";
import BaseLayout from "../layouts/base-layout.astro";

const layers = [
  ["core/*", "Domínios server-side: customers, checkouts, subscriptions, webhooks, benefits, entitlements, meters, seats, portal e license keys."],
  ["stores/postgres", "Fonte da verdade. Guarda customers, subscriptions, catálogo versionado, grants e usage."],
  ["gateways/*", "Adapters substituíveis para Asaas e Abacate Pay. Provider bruto fica aqui."],
  ["integrations/*", "Plugins opcionais para frameworks e ferramentas externas."],
  ["apps/docs", "Landing page e guias de integração."],
];
---
<BaseLayout title="Arquitetura" description="Camadas do HyprPay e limites entre core, store, gateways e integrações." active="/architecture">
  <Hero
    eyebrow="Architecture"
    title="Core pequeno. Estado local. Gateways na borda."
    description="O app fala com HyprPay. HyprPay grava no Postgres e chama o provider apenas quando precisa cobrar, assinar ou normalizar webhook."
  />

  <Section id="design" eyebrow="Design" title="Separação que evita acoplamento.">
    <Features
      items={[
        {
          icon: "blocks",
          title: "Factory única",
          description: "createHyprPay recebe store, provider e catálogo. O restante são sub-APIs pequenas.",
        },
        {
          icon: "book-open-check",
          title: "Catálogo versionado",
          description: "push grava novas versões sem alterar planos antigos já usados em produção.",
        },
        {
          icon: "plug-zap",
          title: "Contrato de gateway",
          description: "Gateways implementam capabilities. O core decide o fallback quando uma capability não existe.",
        },
      ]}
    />
  </Section>

  <Section id="boundaries" eyebrow="Boundaries" title="Estrutura do repo.">
    <Card class="overflow-hidden shadow-sm">
      <CardContent class="divide-y divide-border p-0">
        {layers.map(([name, description]) => (
          <div class="grid gap-3 p-5 md:grid-cols-[220px_1fr]">
            <strong class="font-mono text-primary">{name}</strong>
            <p class="m-0 leading-7 text-muted-foreground">{description}</p>
          </div>
        ))}
      </CardContent>
    </Card>
  </Section>

  <Section id="invariants" eyebrow="Runtime rules" title="Regras do runtime.">
    <Features
      items={[
        {
          icon: "shield-check",
          title: "Sem payload bruto",
          description: "Responses públicas usam schemas normalizados. Payload de webhook fica em BillingEvent.payload.",
        },
        {
          icon: "file-check",
          title: "Falhas tipadas",
          description: "Capability ausente e input inválido falham no error channel do Effect.",
        },
        {
          icon: "layers",
          title: "Core sem framework",
          description: "Integrações ficam fora do core; o runtime continua server-only e sem framework.",
        },
      ]}
    />
  </Section>
</BaseLayout>
