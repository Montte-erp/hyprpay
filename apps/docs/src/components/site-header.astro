---
import Logo from "./logo.astro";
import { Button } from "./starwind/button";
import { topNavItems } from "../navigation";

interface Props {
  active: string;
}

const { active } = Astro.props;
---
<header class="sticky top-0 z-50 h-14 border-b border-border bg-background">
  <div class="mx-auto grid h-full max-w-[1440px] grid-cols-[1fr_auto] items-center lg:grid-cols-[256px_minmax(0,1fr)_180px]">
    <div class="flex h-full items-center border-r border-border px-4">
      <Logo />
    </div>

    <nav class="hidden h-full items-center justify-center gap-12 lg:flex" aria-label="Top navigation">
      {topNavItems.map(item => (
        <a
          href={item.href}
          class:list={[
            "flex h-full items-center border-b px-1 text-[11px] font-semibold tracking-widest transition",
            item.href === active ? "border-foreground text-foreground" : "border-transparent text-muted-foreground hover:text-foreground",
          ]}
        >
          {item.label}
        </a>
      ))}
    </nav>

    <div class="flex h-full items-center justify-end px-3">
      <Button class="h-9 rounded-none px-4 text-xs tracking-wide" variant="default" href="/quickstart">
        QUICKSTART
      </Button>
    </div>
  </div>
</header>
